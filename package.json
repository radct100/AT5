{
  "displayName": "Homebridge Air Touch 5",
  "name": "homebridge-airtouch5",
  "version": "1.0.0",
  "description": "Homebridge plugin for Air Touch 5 HVAC systems",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/radct100/AT5.git"
  },
  "bugs": {
    "url": "https://github.com/radct100/AT5/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "homebridge": ">=1.6.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "lint": "eslint src --ext .ts",
    "build": "tsc",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "airtouch5",
    "hvac",
    "air-conditioning"
  ],
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/homebridge": "^1.6.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "homebridge": "^1.6.0",
    "typescript": "^5.0.0"
  },
  "homebridge": {
    "pluginAlias": "AirTouch5",
    "pluginType": "platform",
    "platforms": [
      {
        "name": "AirTouch5",
        "platform": "AirTouch5"
      }
    ]
  }
}
